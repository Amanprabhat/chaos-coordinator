# ── Application ────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production
PORT=3001
FRONTEND_URL=http://localhost:3000

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=24h

# ── Database ───────────────────────────────────────────────────────────────────
# Development: SQLite is used automatically — no config needed.
#
# Production (PostgreSQL): set DATABASE_URL and NODE_ENV=production
#   Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:password@localhost:5432/chaos_coordinator
#
# Set to "false" only if your PostgreSQL server uses a self-signed cert in a
# trusted private network. Leave unset (defaults to true) for managed cloud DBs.
# DATABASE_SSL=false

# ── Email (optional) ───────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ── File Uploads ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
