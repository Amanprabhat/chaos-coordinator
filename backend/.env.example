# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=24h

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Keycloak SSO ──────────────────────────────────────────────────────────────
# Base URL of your Keycloak server (no trailing slash)
KEYCLOAK_URL=https://auth.example.com

# Realm name configured in Keycloak
KEYCLOAK_REALM=chaos-coordinator

# Client ID and Secret from your Keycloak client registration
KEYCLOAK_CLIENT_ID=chaos-coordinator-app
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret

# Must match exactly what is registered as a Valid Redirect URI in Keycloak
SSO_REDIRECT_URI=http://localhost:3001/api/auth/sso/callback

# ── Role mapping (optional) ───────────────────────────────────────────────────
# By default, Keycloak realm role names are matched case-insensitively against
# Admin, Sales, CSM, PM. Override here if your Keycloak roles use different names.
# KEYCLOAK_ROLE_ADMIN=app-admin
# KEYCLOAK_ROLE_SALES=app-sales
# KEYCLOAK_ROLE_CSM=customer-success
# KEYCLOAK_ROLE_PM=project-manager

# ── Database ──────────────────────────────────────────────────────────────────
# Leave unset to use SQLite (default for development)
# DATABASE_URL=postgresql://user:password@localhost:5432/chaos_coordinator

# ── Email (optional) ──────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=Chaos Coordinator <noreply@example.com>
